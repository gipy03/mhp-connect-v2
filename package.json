{
  "name": "mhp-connect-v2",
  "private": true,
  "version": "2.0.0",
  "description": "mhp | connect 2.0 — Student portal for MHP Hypnose",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter '@mhp/shared' build && pnpm --filter '@mhp/integrations' build && pnpm --parallel --filter './apps/*' build",
    "typecheck": "pnpm --recursive typecheck",
    "db:generate": "pnpm --filter '@mhp/shared' db:generate",
    "db:migrate": "pnpm --filter '@mhp/shared' db:migrate",
    "db:seed": "pnpm --filter '@mhp/shared' db:seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
