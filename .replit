modules = ["nodejs-20", "postgresql-16"]

# Install deps, push schema + seed admin/templates, then start both servers.
# db:seed is idempotent — safe to run on every boot.
run = "pnpm install && pnpm db:seed && pnpm dev"

hidden = [".config", "node_modules", "dist", ".git"]

[nix]
# stable-24_11 ships pnpm 9.x, which matches the lockfileVersion:'9.0' in pnpm-lock.yaml.
channel = "stable-24_11"

[env]
NODE_ENV = "development"
PORT = "5000"

[[ports]]
localPort = 3001
externalPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3003

[[ports]]
localPort = 5003
externalPort = 4200

[[ports]]
localPort = 5173

[[ports]]
localPort = 5174
externalPort = 3001


[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter '@mhp/api' dev & sleep 2 && pnpm --filter '@mhp/web' dev"
waitForPort = 5000

[userenv]

[userenv.production]
NODE_ENV = "production"
PORT = "5000"

[userenv.development]
NODE_ENV = "development"

[userenv.shared]
ENABLE_DEV_CREDS = "true"

[deployment]
deploymentTarget = "cloudrun"
run = ["node", "apps/api/dist/index.js"]
build = ["bash", "build.sh"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
