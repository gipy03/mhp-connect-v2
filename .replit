modules = ["nodejs-20"]

# Install deps then start both servers (API on :5000, Vite on :5173).
# pnpm is provided by replit.nix.
run = "pnpm install && pnpm dev"

hidden = [".config", "node_modules", "dist", ".git"]

[nix]
# stable-24_11 ships pnpm 9.x, which matches the lockfileVersion:'9.0' in pnpm-lock.yaml.
channel = "stable-24_11"

[env]
NODE_ENV = "development"
PORT = "5000"

# ---------------------------------------------------------------------------
# Ports
# Vite (5173) is the public entry point — it proxies /api → Express on 5000.
# Map 5173 → external 80 so Replit's webview opens the right server.
# ---------------------------------------------------------------------------

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 3000

[agent]
expertMode = true
