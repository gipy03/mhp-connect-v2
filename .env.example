# ─────────────────────────────────────────────────────────
#  mhp | connect 2.0 — Environment Variables
#  Copy this file to .env and fill in the values.
#  On Replit, set these as Secrets (not in a .env file).
# ─────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────

# PostgreSQL connection string (Replit provides this via the Database tool)
DATABASE_URL=postgresql://user:password@localhost:5432/mhp_connect

# Session secret — must be at least 32 random characters
SESSION_SECRET=change-me-to-a-random-32-char-secret-value

# ── Optional integrations ──────────────────────────────────

# DigiForma (training management)
DIGIFORMA_API_KEY=

# Bexio (invoicing)
BEXIO_API_TOKEN=

# Accredible (digital certificates)
ACCREDIBLE_WEBHOOK_SECRET=

# SMTP (transactional email)
SMTP_USER=
SMTP_APP_PASSWORD=

# Google Geocoding (directory map)
GOOGLE_GEOCODING_API_KEY=

# ── Seed customisation ────────────────────────────────────

# Admin account created by `pnpm db:seed`
SEED_ADMIN_EMAIL=admin@mhp-hypnose.com
SEED_ADMIN_PASSWORD=Admin123!

# ── Server ────────────────────────────────────────────────

PORT=5000
NODE_ENV=development
